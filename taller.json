  "ontologia": {
    "codigo_manchester_syntax": [
      "Ontology: <http://example.org/cultivos>",

      "Class: Departamento",
      "Class: Municipio",
      "Class: EstacionMeteorologica",
      "Class: Medicion",
      "Class: MedicionHumedad",
      "Class: MedicionPrecipitacion",
      "Class: EvaluacionAgropecuaria",
      "Class: Cultivo",

      "ObjectProperty: perteneceA",
      "ObjectProperty: ubicadaEn",
      "ObjectProperty: generaMedicion",
      "ObjectProperty: registradaEn",
      "ObjectProperty: evalua",

      "DataProperty: tieneCodigoMunicipio",
      "DataProperty: tieneNombre",
      "DataProperty: tieneLatitud",
      "DataProperty: tieneLongitud",
      "DataProperty: tieneFechaObservacion",
      "DataProperty: tieneValorHumedad",
      "DataProperty: tieneValorPrecipitacion",
      "DataProperty: tieneAnio",
      "DataProperty: tieneProduccion",
      "DataProperty: tieneAreaSembrada",

      "Class: MedicionHumedad",
      "    SubClassOf: Medicion",

      "Class: MedicionPrecipitacion",
      "    SubClassOf: Medicion",

      "Class: Municipio",
      "    SubClassOf:",
      "        tieneCodigoMunicipio exactly 1 string,",
      "        tieneNombre exactly 1 string,",
      "        perteneceA exactly 1 Departamento",

      "Class: EstacionMeteorologica",
      "    SubClassOf:",
      "        tieneNombre exactly 1 string,",
      "        tieneLatitud exactly 1 float,",
      "        tieneLongitud exactly 1 float,",
      "        ubicadaEn exactly 1 Municipio",

      "Class: Medicion",
      "    SubClassOf:",
      "        tieneFechaObservacion exactly 1 dateTime,",
      "        generaMedicion exactly 1 EstacionMeteorologica",
  
      "Class: EvaluacionAgropecuaria",
      "    SubClassOf:",
      "        tieneAnio exactly 1 integer,",
      "        tieneProduccion some float,",
      "        registradaEn exactly 1 Municipio,",
      "        evalua exactly 1 Cultivo",
  
      "Class: MunicipioHumedo",
      "    EquivalentTo:",
      "        Municipio and (ubicadaEn some (EstacionMeteorologica and (generaMedicion some (MedicionHumedad and (tieneValorHumedad some float[>= 80])))))",

      "Class: MunicipioLluvioso",
      "    EquivalentTo:",
      "        Municipio and (ubicadaEn some (EstacionMeteorologica and (generaMedicion some (MedicionPrecipitacion and (tieneValorPrecipitacion some float[>= 50])))))",

      "Class: CultivoProductivo",
      "    EquivalentTo:",
      "        Cultivo and (evalua some (EvaluacionAgropecuaria and (tieneProduccion some float[>= 1000])))"
    ],
    
    "reglas_legibles": [
      "Un Municipio pertenece exactamente a 1 Departamento.",
      "Una 'EstacionMeteorologica' esta ubicada exactamente en 1 Municipio.",
      "Una Medición (humedad o precipitación) es generada por exactamente 1 EstaciónMeteorológica.",
      "Una EvaluaciónAgropecuaria se registra en exactamente 1 Municipio y evalúa exactamente 1 Cultivo.",
      "Un MunicipioHúmedo es un Municipio cuyas estaciones reportan humedad ≥ 80 %.",
      "Un MunicipioLluvioso es un Municipio cuyas estaciones reportan precipitación ≥ 50 mm.",
      "Un CultivoProductivo es un Cultivo con producción ≥ 1000 toneladas en alguna evaluación."
    ]
  }
